        "requestId": {
          "type": "string",
          "format": "int64",
          "description": "Set for REQUEST tier: the request ID this config is scoped to."
        },
        "fillerType": {
          "type": "string",
          "description": "Filler actor type (USER | DEPT)."
        },
        "fillerValue": {
          "type": "string",
          "description": "Filler actor value (user_id or dept_id)."
