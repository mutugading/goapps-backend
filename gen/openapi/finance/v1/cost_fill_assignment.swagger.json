        "slaFillHours": {
          "type": "integer",
          "format": "int32",
          "description": "SLA hours allowed for the fill phase before escalation."
        },
        "slaApproveHours": {
          "type": "integer",
          "format": "int32",
          "description": "SLA hours allowed for the approval phase before escalation."
