        "approverType": {
          "type": "string",
          "description": "Approver actor type (USER | DEPT)."
        },
        "approverValue": {
          "type": "string",
          "description": "Approver actor value (user_id or dept_id)."
        },
        "reapproveOnChange": {
          "type": "boolean",
          "description": "Whether the task must be re-approved when any parameter value changes."
