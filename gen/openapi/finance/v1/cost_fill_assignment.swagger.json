        },
        "reapproveOnChange": {
          "type": "boolean",
          "description": "Whether re-approval is triggered on parameter change."
        },
        "slaFillHours": {
          "type": "integer",
          "format": "int32",
          "description": "SLA hours for fill phase (0 = no SLA)."
