      "type": "object",
      "properties": {
        "routeLevel": {
          "type": "integer",
          "format": "int32",
          "description": "Route level to configure (must be \u003e= 1)."
        },
        "tier": {
          "type": "string",
          "description": "Tier scope: GLOBAL, PRODUCT, or REQUEST."
        },
        "productSysId": {
          "type": "string",
          "format": "int64",
          "description": "Required for PRODUCT tier: the target product sys ID."
        },
        "requestId": {
          "type": "string",
          "format": "int64",
          "description": "Required for REQUEST tier: the target request ID."
        },
        "fillerType": {
          "type": "string",
          "description": "Filler actor type identifier."
        },
        "fillerValue": {
          "type": "string",
          "description": "Filler actor value (user_id or dept_id)."
        },
        "approverType": {
          "type": "string",
          "description": "Approver actor type identifier (optional)."
        },
        "approverValue": {
          "type": "string",
