        "parameters": [
          {
            "name": "body",
            "description": "CalculateRMCost runs a calculation synchronously and returns the produced rows.\nIntended for admin/troubleshooting use — production traffic should go through\nTriggerRMCostCalculation.",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1CalculateRMCostRequest"
