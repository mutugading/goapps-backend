    "v1RMCostTriggerReason": {
      "type": "string",
      "enum": [
        "RM_COST_TRIGGER_REASON_UNSPECIFIED",
        "RM_COST_TRIGGER_REASON_ORACLE_SYNC_CHAIN",
        "RM_COST_TRIGGER_REASON_GROUP_UPDATE",
        "RM_COST_TRIGGER_REASON_DETAIL_CHANGE",
        "RM_COST_TRIGGER_REASON_MANUAL_UI"
      ],
      "default": "RM_COST_TRIGGER_REASON_UNSPECIFIED",
      "description": "RMCostTriggerReason enumerates the reasons a calculation was run. Mirrors\n`rmcost.HistoryTriggerReason`.\n\n - RM_COST_TRIGGER_REASON_UNSPECIFIED: Default zero value. Rejected on trigger requests via not_in: [0].\n - RM_COST_TRIGGER_REASON_ORACLE_SYNC_CHAIN: Auto-chained after a successful Oracle sync for the synced period.\n - RM_COST_TRIGGER_REASON_GROUP_UPDATE: Group header changed.\n - RM_COST_TRIGGER_REASON_DETAIL_CHANGE: An item was added/removed/toggled in the group.\n - RM_COST_TRIGGER_REASON_MANUAL_UI: Explicit user request from the UI."
    },
    "v1RMCostType": {
      "type": "string",
      "enum": [
        "RM_COST_TYPE_UNSPECIFIED",
        "RM_COST_TYPE_GROUP",
        "RM_COST_TYPE_ITEM"
      ],
      "default": "RM_COST_TYPE_UNSPECIFIED",
      "description": "RMCostType discriminates a group-level cost row from an item-level cost row.\n\n - RM_COST_TYPE_UNSPECIFIED: Default zero value. Means \"no filter\" in list requests.\n - RM_COST_TYPE_GROUP: Cost row aggregates a whole RM group.\n - RM_COST_TYPE_ITEM: Cost row is computed for a single item (future phase)."
    },
    "v1RMGroupFlag": {
      "type": "string",
      "enum": [
        "RM_GROUP_FLAG_UNSPECIFIED",
        "RM_GROUP_FLAG_INIT",
        "RM_GROUP_FLAG_CONS",
        "RM_GROUP_FLAG_STORES",
        "RM_GROUP_FLAG_DEPT",
        "RM_GROUP_FLAG_PO_1",
        "RM_GROUP_FLAG_PO_2",
        "RM_GROUP_FLAG_PO_3"
      ],
      "default": "RM_GROUP_FLAG_UNSPECIFIED",
      "description": "RMGroupFlag identifies which aggregated stage rate feeds a cost purpose\n(valuation / marketing / simulation), or whether the group uses its\nconfigured init override value. Mirrors the `cst_rm_group_head.flag_*`\ndomain constraint.\n\n - RM_GROUP_FLAG_UNSPECIFIED: Default zero value. Rejected on create/update requests via not_in: [0].\n - RM_GROUP_FLAG_INIT: Use the init_val_* override on the head; skips cascade.\n - RM_GROUP_FLAG_CONS: Use the CONS stage rate.\n - RM_GROUP_FLAG_STORES: Use the STORES stage rate.\n - RM_GROUP_FLAG_DEPT: Use the DEPT stage rate.\n - RM_GROUP_FLAG_PO_1: Use the first PO stage rate.\n - RM_GROUP_FLAG_PO_2: Use the second PO stage rate.\n - RM_GROUP_FLAG_PO_3: Use the third PO stage rate."
    },
    "v1RMMarketingFlag": {
      "type": "string",
      "enum": [
        "RM_MARKETING_FLAG_UNSPECIFIED",
        "RM_MARKETING_FLAG_SP",
        "RM_MARKETING_FLAG_PP",
        "RM_MARKETING_FLAG_FP"
      ],
      "default": "RM_MARKETING_FLAG_UNSPECIFIED",
      "description": "RMMarketingFlag selects which computed marketing projection becomes\n`cost_mark`. UNSPECIFIED behaves as AUTO (SP → PP → FP fallback).\n\n - RM_MARKETING_FLAG_UNSPECIFIED: Default zero value. Treated as AUTO (SP→PP→FP fallback).\n - RM_MARKETING_FLAG_SP: Projection Stock Landed Cost.\n - RM_MARKETING_FLAG_PP: Projection PO Landed Cost.\n - RM_MARKETING_FLAG_FP: Projection Fix Value Landed Cost."
    },
    "v1RMValuationFlag": {
      "type": "string",
      "enum": [
        "RM_VALUATION_FLAG_UNSPECIFIED",
        "RM_VALUATION_FLAG_CR",
        "RM_VALUATION_FLAG_SR",
        "RM_VALUATION_FLAG_PR",
        "RM_VALUATION_FLAG_CL",
        "RM_VALUATION_FLAG_SL",
        "RM_VALUATION_FLAG_FL"
      ],
      "default": "RM_VALUATION_FLAG_UNSPECIFIED",
      "description": "RMValuationFlag selects which computed rate becomes `cost_val` in the\nRM Cost row. UNSPECIFIED behaves as AUTO (CL → SL → FL fallback, where\nFL incorporates the per-detail valuation_default_value).\n\n - RM_VALUATION_FLAG_UNSPECIFIED: Default zero value. Treated as AUTO (CL→SL→FL fallback).\n - RM_VALUATION_FLAG_CR: Use Consumption Rate (CR) — group-total cons_val / cons_qty.\n - RM_VALUATION_FLAG_SR: Use Stock Rate (SR) — group-total stock_val / stock_qty.\n - RM_VALUATION_FLAG_PR: Use PO Rate (PR) — group-total po_val / po_qty.\n - RM_VALUATION_FLAG_CL: Use Consumption Landed Cost (CL) — group-total CL aggregate.\n - RM_VALUATION_FLAG_SL: Use Stock Landed Cost (SL) — group-total SL aggregate.\n - RM_VALUATION_FLAG_FL: Use Fix Landed Cost (FL) — MAX of per-detail FL."
    },
