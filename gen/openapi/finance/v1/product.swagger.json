    "v1CreateProductRequest": {
      "type": "object",
      "properties": {
        "productCode": {
          "type": "string",
          "description": "Unique product code (legacy manual path). Optional in v1.3 when product_type_id is supplied."
        },
        "productName": {
          "type": "string",
          "description": "Display name (1-200 chars)."
        },
        "productItemCode": {
          "type": "string",
          "description": "Oracle item code (1-30 chars)."
