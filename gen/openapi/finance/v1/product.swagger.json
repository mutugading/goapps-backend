        "productKind": {
          "type": "string",
          "description": "Product kind: \"FG\" or \"INTERMEDIATE\" (default FG when empty)."
        },
        "productTypeId": {
          "type": "string",
          "description": "Product type UUID. When supplied, product_code is auto-generated."
        },
        "oracleSysId": {
          "type": "string",
          "description": "Oracle product sys_id (optional lazy link, max 50 chars)."
        }
