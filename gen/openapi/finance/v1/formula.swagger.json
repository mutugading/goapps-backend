            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "formulaId",
            "description": "Formula ID (UUID format).",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "FormulaService"
        ]
      },
      "delete": {
        "summary": "DeleteFormula soft deletes a formula.",
        "operationId": "FormulaService_DeleteFormula",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1DeleteFormulaResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "formulaId",
            "description": "Formula ID to delete (UUID format).",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "FormulaService"
        ]
      },
      "put": {
        "summary": "UpdateFormula updates an existing formula.\nNote: formula_code is immutable and cannot be changed.",
        "operationId": "FormulaService_UpdateFormula",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1UpdateFormulaResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "formulaId",
            "description": "Formula ID to update (UUID format).",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/FormulaServiceUpdateFormulaBody"
            }
          }
        ],
        "tags": [
          "FormulaService"
        ]
      }
    }
