          "type": "string"
        },
        "sourceType": {
          "type": "string",
          "description": "source_type and source_id help correlate the notification with the\nemitting feature (e.g. source_type=\"finance.rm_cost_export\", source_id=job_id)."
        },
        "sourceId": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        },
        "createdBy": {
          "type": "string"
        }
      },
      "description": "Notification represents a single notification record."
    },
    "v1NotificationActionType": {
      "type": "string",
      "enum": [
        "NOTIFICATION_ACTION_TYPE_UNSPECIFIED",
        "NOTIFICATION_ACTION_TYPE_NONE",
        "NOTIFICATION_ACTION_TYPE_NAVIGATE",
        "NOTIFICATION_ACTION_TYPE_DOWNLOAD",
        "NOTIFICATION_ACTION_TYPE_EXTERNAL_LINK",
        "NOTIFICATION_ACTION_TYPE_APPROVE_REJECT",
        "NOTIFICATION_ACTION_TYPE_ACKNOWLEDGE",
        "NOTIFICATION_ACTION_TYPE_MULTI_ACTION",
        "NOTIFICATION_ACTION_TYPE_REPLY",
        "NOTIFICATION_ACTION_TYPE_SNOOZE",
        "NOTIFICATION_ACTION_TYPE_CUSTOM"
      ],
      "default": "NOTIFICATION_ACTION_TYPE_UNSPECIFIED",
      "description": "NotificationActionType controls how the frontend renders the click-action.\nThe shape of action_payload is determined by this value (see proto comments\nfor each variant). Frontend MUST handle CUSTOM as info-only fallback.\n\n - NOTIFICATION_ACTION_TYPE_NONE: No interactive action.\n - NOTIFICATION_ACTION_TYPE_NAVIGATE: payload: {\"path\": \"/foo/bar\"}.\n - NOTIFICATION_ACTION_TYPE_DOWNLOAD: payload: {\"file_path\", \"file_name\", \"size_bytes\", \"expires_at\"}.\n - NOTIFICATION_ACTION_TYPE_EXTERNAL_LINK: payload: {\"url\", \"label\"}.\n - NOTIFICATION_ACTION_TYPE_APPROVE_REJECT: payload: {\"resource_type\",\"resource_id\",\"approve_endpoint\",\"reject_endpoint\"}.\n - NOTIFICATION_ACTION_TYPE_ACKNOWLEDGE: payload: {\"ack_endpoint\"}.\n - NOTIFICATION_ACTION_TYPE_MULTI_ACTION: payload: {\"actions\":[{\"key\",\"label\",\"style\",\"endpoint\"}, ...]}.\n - NOTIFICATION_ACTION_TYPE_REPLY: payload: {\"thread_id\",\"preview\",\"open_path\"}.\n - NOTIFICATION_ACTION_TYPE_SNOOZE: payload: {\"options_minutes\":[15,60,...], \"original_due_at\"}.\n - NOTIFICATION_ACTION_TYPE_CUSTOM: payload: arbitrary; frontend renders info-only."
    },
    "v1NotificationSeverity": {
      "type": "string",
      "enum": [
        "NOTIFICATION_SEVERITY_UNSPECIFIED",
        "NOTIFICATION_SEVERITY_INFO",
        "NOTIFICATION_SEVERITY_SUCCESS",
        "NOTIFICATION_SEVERITY_WARNING",
        "NOTIFICATION_SEVERITY_ERROR"
      ],
      "default": "NOTIFICATION_SEVERITY_UNSPECIFIED",
      "description": "NotificationSeverity drives the visual styling on the frontend.\n\n - NOTIFICATION_SEVERITY_INFO: Neutral information.\n - NOTIFICATION_SEVERITY_SUCCESS: Positive outcome.\n - NOTIFICATION_SEVERITY_WARNING: Caution/attention required.\n - NOTIFICATION_SEVERITY_ERROR: Failure/error condition."
    },
    "v1NotificationStatus": {
      "type": "string",
      "enum": [
        "NOTIFICATION_STATUS_UNSPECIFIED",
        "NOTIFICATION_STATUS_UNREAD",
        "NOTIFICATION_STATUS_READ",
        "NOTIFICATION_STATUS_ARCHIVED"
      ],
      "default": "NOTIFICATION_STATUS_UNSPECIFIED",
      "description": "NotificationStatus is the lifecycle state of a notification.\n\n - NOTIFICATION_STATUS_UNREAD: Recipient has not read yet.\n - NOTIFICATION_STATUS_READ: Recipient has marked read.\n - NOTIFICATION_STATUS_ARCHIVED: Recipient archived (kept until expires_at)."
    },
    "v1NotificationType": {
      "type": "string",
      "enum": [
        "NOTIFICATION_TYPE_UNSPECIFIED",
        "NOTIFICATION_TYPE_EXPORT_READY",
        "NOTIFICATION_TYPE_ALERT",
        "NOTIFICATION_TYPE_APPROVAL",
        "NOTIFICATION_TYPE_CHAT",
        "NOTIFICATION_TYPE_REMINDER",
        "NOTIFICATION_TYPE_SYSTEM",
        "NOTIFICATION_TYPE_MENTION",
        "NOTIFICATION_TYPE_ASSIGNMENT",
        "NOTIFICATION_TYPE_ANNOUNCEMENT"
      ],
      "default": "NOTIFICATION_TYPE_UNSPECIFIED",
      "description": "NotificationType categorizes notifications. Add new values via migration\nonly — backend constraints reference these names.\n\n - NOTIFICATION_TYPE_UNSPECIFIED: Default — used as \"no filter\" in list.\n - NOTIFICATION_TYPE_EXPORT_READY: A generated file is ready for download.\n - NOTIFICATION_TYPE_ALERT: System alert (warning/error).\n - NOTIFICATION_TYPE_APPROVAL: Approval request awaiting recipient action.\n - NOTIFICATION_TYPE_CHAT: Direct chat or comment from another user.\n - NOTIFICATION_TYPE_REMINDER: Time-based reminder.\n - NOTIFICATION_TYPE_SYSTEM: Generic system notification.\n - NOTIFICATION_TYPE_MENTION: The user was mentioned (@username) somewhere.\n - NOTIFICATION_TYPE_ASSIGNMENT: A task/resource was assigned to the user.\n - NOTIFICATION_TYPE_ANNOUNCEMENT: Broadcast announcement to many users."
    },
    "v1PaginationResponse": {
