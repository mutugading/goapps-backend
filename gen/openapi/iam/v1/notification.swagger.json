  "paths": {
    "/api/v1/iam/notifications": {
      "get": {
        "summary": "ListNotifications lists notifications for the authenticated user.",
        "operationId": "NotificationService_ListNotifications",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ListNotificationsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "pageSize",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "status",
            "description": "Filter by status (UNSPECIFIED = all).\n\n - NOTIFICATION_STATUS_UNREAD: Recipient has not read yet.\n - NOTIFICATION_STATUS_READ: Recipient has marked read.\n - NOTIFICATION_STATUS_ARCHIVED: Recipient archived (kept until expires_at).",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": [
              "NOTIFICATION_STATUS_UNSPECIFIED",
              "NOTIFICATION_STATUS_UNREAD",
              "NOTIFICATION_STATUS_READ",
              "NOTIFICATION_STATUS_ARCHIVED"
            ],
            "default": "NOTIFICATION_STATUS_UNSPECIFIED"
          },
          {
            "name": "type",
            "description": "Filter by type (UNSPECIFIED = all).\n\n - NOTIFICATION_TYPE_UNSPECIFIED: Default — used as \"no filter\" in list.\n - NOTIFICATION_TYPE_EXPORT_READY: A generated file is ready for download.\n - NOTIFICATION_TYPE_ALERT: System alert (warning/error).\n - NOTIFICATION_TYPE_APPROVAL: Approval request awaiting recipient action.\n - NOTIFICATION_TYPE_CHAT: Direct chat or comment from another user.\n - NOTIFICATION_TYPE_REMINDER: Time-based reminder.\n - NOTIFICATION_TYPE_SYSTEM: Generic system notification.\n - NOTIFICATION_TYPE_MENTION: The user was mentioned (@username) somewhere.\n - NOTIFICATION_TYPE_ASSIGNMENT: A task/resource was assigned to the user.\n - NOTIFICATION_TYPE_ANNOUNCEMENT: Broadcast announcement to many users.",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": [
              "NOTIFICATION_TYPE_UNSPECIFIED",
              "NOTIFICATION_TYPE_EXPORT_READY",
              "NOTIFICATION_TYPE_ALERT",
              "NOTIFICATION_TYPE_APPROVAL",
              "NOTIFICATION_TYPE_CHAT",
              "NOTIFICATION_TYPE_REMINDER",
              "NOTIFICATION_TYPE_SYSTEM",
              "NOTIFICATION_TYPE_MENTION",
              "NOTIFICATION_TYPE_ASSIGNMENT",
              "NOTIFICATION_TYPE_ANNOUNCEMENT"
            ],
            "default": "NOTIFICATION_TYPE_UNSPECIFIED"
          },
          {
            "name": "sortOrder",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "NotificationService"
        ]
      },
      "post": {
        "summary": "CreateNotification creates a new notification for a user. Used by other\nservices (e.g. finance worker emitting EXPORT_READY).",
        "operationId": "NotificationService_CreateNotification",
        "responses": {
