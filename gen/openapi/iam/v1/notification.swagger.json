    "v1Notification": {
      "type": "object",
      "properties": {
        "notificationId": {
          "type": "string"
        },
        "recipientUserId": {
          "type": "string"
        },
        "type": {
          "$ref": "#/definitions/v1NotificationType"
        },
        "severity": {
          "$ref": "#/definitions/v1NotificationSeverity"
        },
        "title": {
          "type": "string"
        },
        "body": {
          "type": "string"
        },
        "actionType": {
          "$ref": "#/definitions/v1NotificationActionType"
        },
        "actionPayload": {
          "type": "string",
          "description": "action_payload is a JSON-encoded string whose shape depends on\naction_type — see enum comments. Empty string when action_type=NONE."
        },
        "status": {
