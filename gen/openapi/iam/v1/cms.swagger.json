            "required": false,
            "type": "string",
            "enum": [
              "CMS_SECTION_TYPE_UNSPECIFIED",
              "CMS_SECTION_TYPE_HERO",
              "CMS_SECTION_TYPE_FEATURE",
              "CMS_SECTION_TYPE_FAQ",
              "CMS_SECTION_TYPE_TESTIMONIAL",
              "CMS_SECTION_TYPE_CTA",
              "CMS_SECTION_TYPE_CUSTOM"
            ],
            "default": "CMS_SECTION_TYPE_UNSPECIFIED"
