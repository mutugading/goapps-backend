# =============================================================================
# Finance Service - Environment Variables
# These override values in config.yaml via Viper's env binding.
# For local dev, config.yaml defaults are usually sufficient.
# Copy to .env and adjust only what you need to override.
# =============================================================================

# --- App ---
# APP_ENV=development                    # development | staging | production
# LOG_LEVEL=debug                        # debug | info | warn | error

# --- Database (PostgreSQL) ---
# DATABASE_HOST=localhost
# DATABASE_PORT=5434
# DATABASE_USER=finance
# DATABASE_PASSWORD=finance123
# DATABASE_NAME=finance_db
# DATABASE_SSLMODE=disable

# --- Redis (UOM cache, DB 0) ---
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# --- Auth Redis (shared with IAM for token blacklist, DB 1) ---
# AUTH_REDIS_HOST=localhost
# AUTH_REDIS_PORT=6379
# AUTH_REDIS_PASSWORD=
# AUTH_REDIS_DB=1

# --- JWT (MUST match IAM service secret for SSO token validation) ---
# JWT_ACCESS_SECRET=dev-access-secret-change-in-production

# --- Oracle (for Oracle Sync worker) ---
# ORACLE_HOST=localhost                   # Oracle DB host (or 192.168.0.7 for staging)
# ORACLE_PORT=1521                        # Oracle DB port
# ORACLE_SERVICE=ORCLPDB1                 # Oracle service name
# ORACLE_USER=                            # Oracle schema user
# ORACLE_PASSWORD=                        # Oracle schema password

# --- RabbitMQ (for Oracle Sync job queue) ---
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# --- CORS ---
# CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Tracing (Jaeger/OpenTelemetry) ---
# TRACING_ENABLED=true
# JAEGER_ENDPOINT=localhost:4317

# --- IAM gRPC client (worker → IAM for notifications) ---
# IAM_GRPC_HOST=localhost
# IAM_GRPC_PORT=50052

# --- MinIO storage (worker uploads xlsx exports here) ---
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=goapps-staging
# MINIO_USE_SSL=false
# MINIO_PUBLIC_URL=

# --- Internal service-to-service token ---
# Shared secret sent in `x-internal-token` metadata to IAM. MUST match
# iam/.env.local:INTERNAL_SERVICE_TOKEN. Used by finance-worker to call IAM
# CreateNotification without a user JWT.
INTERNAL_SERVICE_TOKEN=dev-internal-service-token-change-me
