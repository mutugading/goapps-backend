{{define "base"}}<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <!--[if mso]><xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch><o:AllowPNG/></o:OfficeDocumentSettings></xml><![endif]-->
</head>
<body style="margin:0; padding:0; background-color:#eff6ff; font-family:Arial,Helvetica,sans-serif; -webkit-font-smoothing:antialiased; mso-line-height-rule:exactly;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" bgcolor="#eff6ff">
    <tr>
      <td align="center" style="padding:32px 16px 40px 16px;">
        <!--[if mso]><table width="600" align="center" cellpadding="0" cellspacing="0" border="0"><tr><td><![endif]-->
        <!-- width:100% + max-width:600px keeps it fluid on mobile, Outlook uses the MSO 600px wrapper above -->
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="max-width:600px; width:100%;">

          <!-- ===== CARD ===== -->
          <tr>
            <td style="border-radius:16px; border:1px solid #dbeafe; overflow:hidden; box-shadow:0 4px 24px rgba(59,130,246,0.08);">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">

                <!-- HERO BANNER: identity row + centered title — all on background image -->
                <tr>
                  <td bgcolor="#1d4ed8" style="border-radius:16px 16px 0 0; overflow:hidden; padding:0;">
                    <!--[if mso]><table width="100%" cellpadding="0" cellspacing="0" border="0"><tr><td style="background-color:#1d4ed8;"><![endif]-->
                    {{if .HeaderBgURL}}
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="padding:0; background-image:url('{{.HeaderBgURL | safeURL}}'); background-size:cover; background-position:center top;">
                          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                              <td style="background-color:rgba(29,78,216,0.82);">
                                {{template "hero-inner" .}}
                              </td>
                            </tr>
                          </table>
                        </td>
                      </tr>
                    </table>
                    {{else}}
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="background-color:#1d4ed8;">
                          {{template "hero-inner" .}}
                        </td>
                      </tr>
                    </table>
                    {{end}}
                    <!--[if mso]></td></tr></table><![endif]-->
                  </td>
                </tr>

                <!-- CONTENT -->
                <tr>
                  <td style="padding:28px 28px 24px 28px; background-color:#ffffff;">
                    {{template "content" .}}
                  </td>
                </tr>

                <!-- FOOTER -->
                <tr>
                  <td style="padding:0; background-color:#f0f6ff; border-radius:0 0 16px 16px;">

                    <!-- Social icons: hosted PNG images (Gmail/Outlook safe, no SVG, no data: URI) -->
                    {{if .SocialLinks}}
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td align="center" style="padding:20px 28px 12px 28px;">
                          <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                              {{range .SocialLinks}}
                              <td style="padding:0 6px;">
                                {{if .IconURL}}
                                <a href="{{.URL}}" style="text-decoration:none; display:block;" title="{{.Name}}">
                                  <img src="{{.IconURL | safeURL}}" width="30" height="30" alt="{{.Name}}" style="display:block; border:0; border-radius:15px;">
                                </a>
                                {{else}}
                                <!--[if mso]><v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word" href="{{.URL}}" style="height:28px;v-text-anchor:middle;width:90px;" arcsize="50%" stroke="f" {{if eq .Name "LinkedIn"}}fillcolor="#0A66C2"{{else if eq .Name "Instagram"}}fillcolor="#E4405F"{{else}}fillcolor="#2563EB"{{end}}><w:anchorlock/><center style="color:#ffffff;font-family:Arial,sans-serif;font-size:11px;font-weight:700;">{{.Name}}</center></v:roundrect><![endif]-->
                                <!--[if !mso]><!-->
                                <a href="{{.URL}}" style="display:inline-block;padding:6px 14px;border-radius:14px;font-family:Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;color:#ffffff;text-decoration:none;mso-hide:all;{{if eq .Name "LinkedIn"}}background-color:#0A66C2;{{else if eq .Name "Instagram"}}background-color:#E4405F;{{else}}background-color:#2563EB;{{end}}">{{.Name}}</a>
                                <!--<![endif]-->
                                {{end}}
                              </td>
                              {{end}}
                            </tr>
                          </table>
                        </td>
                      </tr>
                    </table>
                    {{end}}

                    <!-- Nav links: app · support · terms & conditions · privacy policy -->
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td align="center" style="padding:{{if .SocialLinks}}4px{{else}}20px{{end}} 28px 4px 28px;">
                          <p style="margin:0; font-size:12px; color:#5c5f61; font-family:Arial,Helvetica,sans-serif; line-height:1.8;">
                            <a href="{{.AppURL}}" style="color:#3b82f6; text-decoration:none; font-weight:600;">{{.AppName}}</a>{{if .SupportURL}}&nbsp;&middot;&nbsp;<a href="{{.SupportURL}}" style="color:#3b82f6; text-decoration:none;">Support</a>{{end}}{{if .TermsURL}}&nbsp;&middot;&nbsp;<a href="{{.TermsURL}}" style="color:#3b82f6; text-decoration:none;">Terms &amp; Conditions</a>{{end}}{{if .PrivacyURL}}&nbsp;&middot;&nbsp;<a href="{{.PrivacyURL}}" style="color:#3b82f6; text-decoration:none;">Privacy Policy</a>{{end}}
                          </p>
                        </td>
                      </tr>
                    </table>

                    <!-- Copyright + address -->
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td align="center" style="padding:6px 28px 20px 28px;">
                          <p style="margin:0 0 2px 0; font-size:11px; color:#777587; font-family:Arial,Helvetica,sans-serif;">&copy; {{.Year}} {{if .CompanyName}}{{.CompanyName}}{{else}}{{.AppName}}{{end}}. All rights reserved.</p>
                          {{if .CompanyAddress}}
                          <p style="margin:0; font-size:11px; color:#9b99a6; font-family:Arial,Helvetica,sans-serif;">{{.CompanyAddress}}</p>
                          {{end}}
                        </td>
                      </tr>
                    </table>

                  </td>
                </tr>

              </table>
            </td>
          </tr>

        </table>
        <!--[if mso]></td></tr></table><![endif]-->
      </td>
    </tr>
  </table>
</body>
</html>
{{end}}

{{define "hero-inner"}}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
  <!-- Identity row: logo + appname + company (left) | tagline (right) -->
  <tr>
    <td style="padding:20px 24px 0 24px;">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
          <!-- Left: logo + app name + company name -->
          <td valign="middle">
            <table role="presentation" cellpadding="0" cellspacing="0" border="0">
              <tr>
                {{if .LogoURL}}
                <td valign="middle" style="padding-right:9px;">
                  <a href="{{.AppURL}}" style="text-decoration:none; display:block;">
                    <img src="{{.LogoURL | safeURL}}" alt="{{.AppName}}" height="30" style="display:block; border:0; height:30px; width:auto; max-width:110px;">
                  </a>
                </td>
                {{end}}
                <td valign="middle">
                  <a href="{{.AppURL}}" style="text-decoration:none; display:block;">
                    <span style="font-size:14px; font-weight:700; color:#ffffff; font-family:Arial,Helvetica,sans-serif; letter-spacing:-0.2px;">{{.AppName}}</span>
                  </a>
                  {{if .CompanyName}}
                  <p style="margin:2px 0 0 0; font-size:10px; color:rgba(255,255,255,0.68); font-family:Arial,Helvetica,sans-serif; letter-spacing:0.01em;">{{.CompanyName}}</p>
                  {{end}}
                </td>
              </tr>
            </table>
          </td>
          <!-- Right: tagline — hide on very small screens via max-width trick -->
          {{if .HeaderTagline}}
          <td valign="middle" align="right" style="max-width:180px;">
            <span style="font-size:10px; color:rgba(255,255,255,0.65); font-family:Arial,Helvetica,sans-serif; font-style:italic;">{{.HeaderTagline}}</span>
          </td>
          {{end}}
        </tr>
      </table>
    </td>
  </tr>
  <!-- Centered title + subtitle -->
  <tr>
    <td align="center" style="padding:24px 24px 32px 24px;">
      {{if .HeaderSubtitle}}
      <p style="margin:0 0 10px 0; font-size:11px; font-weight:700; color:rgba(255,255,255,0.75); font-family:Arial,Helvetica,sans-serif; letter-spacing:0.10em; text-transform:uppercase;">{{.HeaderSubtitle}}</p>
      {{end}}
      {{if .HeaderTitle}}
      <h1 style="margin:0; font-size:26px; font-weight:700; color:#ffffff; font-family:Arial,Helvetica,sans-serif; letter-spacing:-0.4px; line-height:1.2;">{{.HeaderTitle}}</h1>
      {{end}}
    </td>
  </tr>
</table>
{{end}}
