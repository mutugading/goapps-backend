{{define "content"}}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
  <!-- Heading -->
  <tr>
    <td style="padding-bottom:20px;">
      <div style="display:inline-block; width:44px; height:44px; border-radius:50%; background-color:#f0f3ff; text-align:center; line-height:44px; font-size:20px; margin-bottom:12px;">&#128737;</div>
      <h1 style="margin:8px 0 6px 0; font-size:20px; font-weight:700; color:#111c2d; font-family:Arial,Helvetica,sans-serif; letter-spacing:-0.3px;">Security Update</h1>
      <p style="margin:0; font-size:14px; color:#5c5f61; font-family:Arial,Helvetica,sans-serif; line-height:1.5;">
        Hi{{if .RecipientName}} {{.RecipientName}}{{end}},<br>
        <strong style="color:#111c2d;">{{.Feature}}</strong> has been <strong style="color:#111c2d;">{{.Action}}</strong> on your account.
      </p>
    </td>
  </tr>
  <!-- Details table -->
  <tr>
    <td style="padding-bottom:20px;">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" bgcolor="#f0f3ff" style="border:1px solid #dee8ff; border-radius:8px;">
        <tr>
          <td style="padding:16px 20px;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td width="140" valign="top" style="font-size:12px; font-weight:600; color:#5c5f61; text-transform:uppercase; letter-spacing:0.05em; font-family:Arial,Helvetica,sans-serif; padding-bottom:10px;">Change</td>
                <td style="font-size:13px; color:#111c2d; font-family:Arial,Helvetica,sans-serif; padding-bottom:10px;">{{.Feature}} {{.Action}}</td>
              </tr>
              {{if .OccurredAt}}
              <tr>
                <td width="140" valign="top" style="font-size:12px; font-weight:600; color:#5c5f61; text-transform:uppercase; letter-spacing:0.05em; font-family:Arial,Helvetica,sans-serif; padding-bottom:10px;">Time</td>
                <td style="font-size:13px; color:#111c2d; font-family:Arial,Helvetica,sans-serif; padding-bottom:10px;">{{.OccurredAt}}</td>
              </tr>
              {{end}}
              {{if .IPAddress}}
              <tr>
                <td width="140" valign="top" style="font-size:12px; font-weight:600; color:#5c5f61; text-transform:uppercase; letter-spacing:0.05em; font-family:Arial,Helvetica,sans-serif; padding-bottom:10px;">IP Address</td>
                <td style="font-size:13px; color:#111c2d; font-family:Arial,Helvetica,sans-serif; padding-bottom:10px;">{{.IPAddress}}</td>
              </tr>
              {{end}}
              {{if .UserAgent}}
              <tr>
                <td width="140" valign="top" style="font-size:12px; font-weight:600; color:#5c5f61; text-transform:uppercase; letter-spacing:0.05em; font-family:Arial,Helvetica,sans-serif;">Device</td>
                <td style="font-size:13px; color:#111c2d; font-family:Arial,Helvetica,sans-serif;">{{.UserAgent}}</td>
              </tr>
              {{end}}
            </table>
          </td>
        </tr>
      </table>
    </td>
  </tr>
  <!-- Warning notice -->
  <tr>
    <td style="padding-bottom:20px;">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" bgcolor="#ffdad6" style="border:1px solid #f5c6c1; border-radius:8px;">
        <tr>
          <td style="padding:14px 16px;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td width="24" valign="top" style="padding-right:8px; font-size:16px; color:#ba1a1a; line-height:20px; font-family:Arial,Helvetica,sans-serif;">&#9888;</td>
                <td>
                  <p style="margin:0; font-size:13px; color:#93000a; font-family:Arial,Helvetica,sans-serif; line-height:1.5;">If you did not make this change, please review your account security immediately.</p>
                </td>
              </tr>
            </table>
          </td>
        </tr>
      </table>
    </td>
  </tr>
  <!-- CTA button -->
  {{if .SecureURL}}
  <tr>
    <td align="center" style="padding-bottom:8px;">
      <a href="{{.SecureURL}}" style="display:inline-block; padding:12px 28px; background-color:#3525cd; color:#ffffff; font-size:14px; font-weight:600; text-decoration:none; border-radius:6px; font-family:Arial,Helvetica,sans-serif; mso-padding-alt:0; letter-spacing:0.02em;">Review Account</a>
    </td>
  </tr>
  {{end}}
</table>
{{end}}
